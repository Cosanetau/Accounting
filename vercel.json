{
  "buildCommand": "npm run build",
  "framework": "vite",
  "installCommand": "npm install",
  "functions": {
    "api/accounting.js": {
      "maxDuration": 60
    },
    "api/stripe-webhook.js": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/"
    }
  ]
}
